    \caption<{кати̂пез} (√[к]-[т]-[п], G-[е] 型)>
    \tr<\th;\th<現.能>\th<現.受>\th<過.能>\th<過.受>>
    \tr<\th<三.定.水>\td<{кати̂пез}>\td<{до̀кти̂пез}>\td<{кати̂пнез}>\td<{до̀кти̂пнез}>>
