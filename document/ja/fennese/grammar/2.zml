    \tr<\th<対.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥра]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥра]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревах]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровах]>>
    \tr<\th<与.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҫ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҫ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреваҫ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроваҫ]>>
    \tr<\th<奪.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреӟам]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроӟам]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥӟам]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥӟам]>>
    \tr<\th<具.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреўат]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроўат]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥўат]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥўат]>>
    \tr<\th<処.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥрей]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥрой]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревай]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровай]>>
    \tr<\th<主.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ар]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥро]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥрев]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥров]>>
    \tr<\th<対.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥра]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥра]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревах]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровах]>>
    \tr<\th<与.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҫ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҫ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреваҫ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроваҫ]>>
    \tr<\th<奪.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреӟам]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроӟам]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥӟам]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥӟам]>>
