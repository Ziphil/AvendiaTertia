    \tr<\th<三.不定.火>\td<{акти̂поз}>\td<{адо̀кти̂поз}>\td<{акти̂пноз}>\td<{адо̀кти̂пноз}>>
    \tr<\th<二.水>\td<{текти̂пез}>\td<{тедо̀кти̂пез}>\td<{текти̂пнез}>\td<{тедо̀кти̂пнез}>>
    \tr<\th<二.火>\td<{токти̂поз}>\td<{тодо̀кти̂поз}>\td<{токти̂пноз}>\td<{тодо̀кти̂пноз}>>
