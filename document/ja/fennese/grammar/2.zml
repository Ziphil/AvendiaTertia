    \tr<\th<一複.火>\td<{бамокти̂поз}>\td<{бамодо̀кти̂поз}>\td<{бамокти̂пноз}>\td<{бамодо̀кти̂пноз}>>
    \tr<\th<一単.水>\td<{икти̂пез}>\td<{идо̀кти̂пез}>\td<{икти̂пнез}>\td<{идо̀кти̂пнез}>>
    \tr<\th<一単.火>\td<{екти̂поз}>\td<{едо̀кти̂поз}>\td<{екти̂пноз}>\td<{едо̀кти̂пноз}>>
  >
  \h3|tag="tbg"|<形容詞か名詞として>
  \p<
    再帰用言が形容詞や名詞として用いられる場合でも、\mk;[‧ҙ] の前に挿入される母音は同様である。
  >
  \p<
    参考として、G 型での屈折における形容詞能動態の基層形と、それを語根 √[к]‧[т]‧[п] に適用して得られる表層形を列挙する。
    連続軽音節を回避するために消失する母音にはストローク符号を付けた。
  >
  \table<
    \caption<G 型>
    \tr<\th<形.能>\th<水.用>\th<火.用>\th<水.体>\th<火.体>>
    \tr<\th<主.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреваҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроваҙ]>>
    \tr<\th<対.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥраҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥраҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥхаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥхаҙ]>>
    \tr<\th<与.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҫаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҫаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥҫаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥҫаҙ]>>
    \tr<\th<奪.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреӟⱥмаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроӟⱥмаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥӟамаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥӟамаҙ]>>
    \tr<\th<具.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреўⱥтаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроўⱥтаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥўатаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥўатаҙ]>>
    \tr<\th<処.不定>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥрейаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥройаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥйаҙ]>\td<\mk;\rd<[к]>[а]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥйаҙ]>>
    \tr<\th<主.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреваҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроваҙ]>>
    \tr<\th<対.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥраҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥраҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥхаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥхаҙ]>>
    \tr<\th<与.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреҫаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроҫаҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥҫаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥҫаҙ]>>
    \tr<\th<奪.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреӟⱥмаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроӟⱥмаҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥӟамаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥӟамаҙ]>>
    \tr<\th<具.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥреўⱥтаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥроўⱥтаҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥўатаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥўатаҙ]>>
    \tr<\th<処.定>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥрейаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥройаҙ]>\td<\mk;[ле]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥревⱥйаҙ]>\td<\mk;[ло]\rd<[к]>[ⱥ]\rd<[т]>[\d|t="c"|<ꙙ>]\rd<[п]>[ⱥровⱥйаҙ]>>
  >
  \table<
    \caption<{кати̂пез} (√[к]‧[т]‧[п], G-[и] 型)>
    \tr<\th<形.能>\th<水.用>\th<火.用>\th<水.体>\th<火.体>>
    \tr<\th<主.不定>\td<{кати̂през}>\td<{кати̂проз}>\td<{кати̂преваз}>\td<{кати̂проваз}>>
